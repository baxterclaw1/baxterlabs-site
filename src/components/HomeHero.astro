---
const words = [
  'the busywork',
  'the invoice chasing',
  'the follow-up emails',
  'the data entry',
  'the document signing',
  'the weekly reports',
];
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="hero-inner">
    <h1 class="hero-title">
      <span class="hero-line">We automate</span>
      <span class="hero-slot">
        <span class="sr-only">{words[0]}.</span>
        <span class="hero-rotator" aria-hidden="true">
          {words.map((word, i) => <span class:list={['hero-word', { 'is-current': i === 0 }]}>{word}</span>)}
        </span>
      </span>
    </h1>
    <p class="hero-sub">
      Your business has evolved. Your tools should too.
    </p>
  </div>
</section>

<script>
  const rotator = document.querySelector('.hero-rotator');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (rotator && !reduce) {
    const words = Array.from(rotator.querySelectorAll('.hero-word'));
    let index = 0;

    setInterval(() => {
      if (document.hidden) return;
      const current = words[index];
      index = (index + 1) % words.length;
      const next = words[index];

      current.classList.remove('is-current');
      current.classList.add('is-leaving');
      window.setTimeout(() => current.classList.remove('is-leaving'), 650);
      next.classList.add('is-current');
    }, 2600);
  }
</script>

<style>
  .hero {
    position: relative;
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--section-pad-x);
    /* Fill the first screen so How we work starts below the fold */
    min-height: calc(100dvh - 3.25rem);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(ellipse 85% 55% at 50% 0%, rgba(224, 122, 95, 0.1), transparent 58%),
      radial-gradient(ellipse 45% 35% at 70% 40%, rgba(255, 255, 255, 0.04), transparent 50%);
  }

  .hero-inner {
    position: relative;
    width: 100%;
    max-width: 58rem;
    /* Half the previous lift — nudged up from center, not top-heavy */
    padding: clamp(2rem, 5vw, 3.5rem) 0 clamp(1.5rem, 3vw, 2rem);
    transform: translateY(-9vh);
    text-align: center;
    z-index: 1;
  }

  .hero-title {
    font-size: clamp(2.835rem, 8.55vw, 5.175rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.08;
  }

  .hero-line {
    display: block;
  }

  .hero-slot {
    display: block;
    position: relative;
    height: 1.28em;
    overflow: hidden;
  }

  .hero-rotator {
    display: block;
    position: absolute;
    inset: 0;
  }

  .hero-word {
    position: absolute;
    inset: 0;
    display: block;
    text-align: center;
    white-space: nowrap;
    color: var(--site-accent);
    opacity: 0;
    transform: translateY(0);
  }

  .hero-word.is-current {
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-word {
      transform: translateY(108%);
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.45s ease;
    }

    .hero-word.is-current {
      transform: translateY(0);
    }

    .hero-word.is-leaving {
      opacity: 0;
      transform: translateY(-108%);
    }

    .hero-line,
    .hero-slot {
      animation: hero-rise 0.55s ease-out both;
    }

    .hero-slot {
      animation-delay: 0.12s;
    }

    .hero-sub {
      animation: hero-fade 0.5s ease-out 0.3s both;
    }

    @keyframes hero-rise {
      from {
        opacity: 0;
        transform: translateY(16px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes hero-fade {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }

  .hero-sub {
    font-size: clamp(1.18125rem, 2.52vw, 1.51875rem);
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.4;
    color: var(--site-text-dim);
    max-width: 38rem;
    margin: clamp(1.15rem, 2.5vw, 1.6rem) auto 0;
    text-wrap: pretty;
  }

  /* Phone only — larger type, still fits the longest rotating phrases */
  @media (max-width: 640px) {
    .hero {
      padding: 0 1rem;
      max-width: 100%;
    }

    .hero-inner {
      max-width: 100%;
      transform: translateY(-6vh);
    }

    .hero-title {
      /* ~60% of the way back from the too-small pass toward the original 3.15rem */
      font-size: clamp(2.4rem, 9.7vw, 2.75rem);
      letter-spacing: -0.035em;
    }

    .hero-line {
      white-space: nowrap;
    }

    .hero-slot {
      height: 2.4em;
    }

    .hero-word {
      display: flex;
      align-items: center;
      justify-content: center;
      white-space: normal;
      line-height: 1.12;
      text-wrap: balance;
    }

    .hero-sub {
      font-size: clamp(1.15rem, 4.2vw, 1.3rem);
      max-width: 22rem;
    }
  }

  /* Fold cover / very narrow — prevent overflow that triggers page shrink */
  @media (max-width: 400px) {
    .hero {
      padding: 0 0.75rem;
    }

    .hero-inner {
      transform: translateY(-4vh);
    }

    .hero-title {
      font-size: clamp(1.85rem, 9.5vw, 2.35rem);
    }

    .hero-line {
      white-space: normal;
    }

    .hero-slot {
      height: 2.5em;
    }

    .hero-sub {
      font-size: clamp(1rem, 4vw, 1.15rem);
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
