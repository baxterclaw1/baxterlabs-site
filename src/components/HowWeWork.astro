---
const steps = [
  {
    n: '01',
    title: 'We look at how you run',
    body: 'A clear look at your day-to-day — where time goes, what slows you down, and what to improve first for the biggest return.',
  },
  {
    n: '02',
    title: 'We propose what fits',
    body: 'A plan built around the tools you already use. Email, intake, dashboards — whatever unlocks capacity without starting over.',
  },
  {
    n: '03',
    title: 'You see what changes',
    body: 'What gets built, what you can expect, and what it looks like in practice. Straight answers stay below.',
  },
  {
    n: '04',
    title: 'If you want more, reach out',
    body: 'Ready to talk it through? The contact form below is the next step.',
  },
];
---

<section class="process" aria-labelledby="process-heading">
  <div class="process-head" data-reveal>
    <p class="process-label">Placeholder</p>
    <h2 id="process-heading">How we work</h2>
    <p class="process-lead">Outline for now. Final layout and polish come later.</p>
  </div>

  <ol class="process-list">
    {
      steps.map((step, i) => (
        <li class="process-item" data-reveal style={`--reveal-delay: ${(i + 1) * 0.05}s`}>
          <span class="process-n">{step.n}</span>
          <div class="process-body">
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
        </li>
      ))
    }
  </ol>
</section>
