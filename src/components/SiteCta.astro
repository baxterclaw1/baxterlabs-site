---
const contactEmail = 'baxterlabs.io@gmail.com';
---

<section class="site-cta" id="contact" aria-labelledby="cta-heading">
  <div class="site-cta-panel">
    <div class="site-section-head">
      <h2 id="cta-heading" class="site-section-title">Ready to see what's possible?</h2>
      <p class="site-section-subtitle">
        Book a 30-minute consultation. We'll discuss your biggest bottlenecks and explore if automation is right for you.
      </p>
    </div>

    <form class="site-contact" id="contact-form" novalidate>
      <input type="text" name="_gotcha" class="site-contact-honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />

      <div class="site-contact-row">
        <label class="site-contact-field">
          <span>Name</span>
          <input type="text" name="name" required autocomplete="name" placeholder="Your name" />
        </label>
        <label class="site-contact-field">
          <span>Email</span>
          <input type="email" name="email" required autocomplete="email" placeholder="you@company.com" />
        </label>
      </div>

      <label class="site-contact-field">
        <span>Business <em>(optional)</em></span>
        <input type="text" name="business" autocomplete="organization" placeholder="Company name" />
      </label>

      <label class="site-contact-field">
        <span>What's going on</span>
        <textarea
          name="message"
          required
          rows="5"
          placeholder="What's stuck, the tools you use, or what you'd like us to look at."
        ></textarea>
      </label>

      <div class="site-contact-footer">
        <button class="btn" type="submit" id="contact-submit">Send message</button>
        <p class="site-contact-status" id="contact-status" role="status" aria-live="polite" hidden></p>
      </div>
    </form>
  </div>
</section>

<script define:vars={{ contactEmail }}>
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('contact-submit');
  const statusEl = document.getElementById('contact-status');

  if (form && submitBtn && statusEl) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const honeypot = form.querySelector('[name="_gotcha"]');
      if (honeypot instanceof HTMLInputElement && honeypot.value) return;

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const data = new FormData(form);
      data.append('_subject', 'BaxterLabs site inquiry');
      data.append('_template', 'table');

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';
      statusEl.hidden = true;

      try {
        const res = await fetch(`https://formsubmit.co/ajax/${contactEmail}`, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: data,
        });

        if (!res.ok) throw new Error('Request failed');

        form.reset();
        statusEl.hidden = false;
        statusEl.dataset.state = 'ok';
        statusEl.textContent = "Got it. We'll get back to you soon.";
      } catch {
        statusEl.hidden = false;
        statusEl.dataset.state = 'err';
        statusEl.textContent = `Something went wrong. Email us at ${contactEmail}.`;
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send message';
      }
    });
  }
</script>

<style>
  .site-cta {
    width: 100%;
    max-width: none;
    margin: 0;
    padding: var(--section-pad-y) var(--section-pad-x);
    background: linear-gradient(
      180deg,
      rgba(224, 122, 95, 0.14) 0%,
      rgba(224, 122, 95, 0.05) 55%,
      var(--site-bg) 100%
    );
    position: relative;
  }

  .site-cta-panel {
    max-width: var(--content-width);
    margin: 0 auto;
    border: 1px solid rgba(224, 122, 95, 0.35);
    background: var(--site-bg);
    box-shadow:
      0 0 0 1px rgba(224, 122, 95, 0.1),
      0 0 36px rgba(224, 122, 95, 0.22),
      0 0 80px rgba(224, 122, 95, 0.1);
    padding: clamp(2rem, 4vw, 3rem) clamp(1.5rem, 4vw, 2.75rem) clamp(2rem, 4vw, 2.75rem);
  }

  .site-cta-panel .site-section-head {
    margin-bottom: 2.25rem;
  }

  .site-contact {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 48rem;
    margin: 0 auto;
    width: 100%;
  }

  .site-contact-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .site-contact-row {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 560px) {
    .site-contact-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .site-contact-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.8125rem;
    color: var(--site-text-dim);
  }

  .site-contact-field em {
    font-style: normal;
    color: var(--site-text-muted);
  }

  .site-contact-field input,
  .site-contact-field textarea {
    width: 100%;
    padding: 0.75rem 0.9rem;
    font-family: inherit;
    font-size: 0.9375rem;
    color: var(--site-text);
    background: var(--site-surface);
    border: 1px solid var(--site-border);
    border-radius: 0;
    outline: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .site-contact-field textarea {
    resize: none;
    min-height: 8rem;
    line-height: 1.5;
  }

  .site-contact-field input::placeholder,
  .site-contact-field textarea::placeholder {
    color: var(--site-text-muted);
    font-style: italic;
  }

  .site-contact-field input:focus,
  .site-contact-field textarea:focus {
    border-color: var(--site-accent);
    box-shadow: 0 0 0 3px var(--site-glow);
  }

  .site-contact-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 0.25rem;
  }

  .site-contact-footer .btn:disabled {
    opacity: 0.7;
    cursor: wait;
    transform: none;
    box-shadow: none;
  }

  .site-contact-status {
    font-size: 0.875rem;
    color: var(--site-text-dim);
  }

  .site-contact-status[data-state='ok'] {
    color: #8fbf9f;
  }

  .site-contact-status[data-state='err'] {
    color: var(--site-accent);
  }
</style>
