---
const logos = [
  { slug: 'quickbooks', name: 'QuickBooks' },
  { slug: 'gmail', name: 'Gmail' },
  { slug: 'googlesheets', name: 'Google Sheets' },
  { slug: 'hubspot', name: 'HubSpot' },
  { slug: 'stripe', name: 'Stripe' },
  { slug: 'shopify', name: 'Shopify' },
  { slug: 'xero', name: 'Xero' },
  { slug: 'notion', name: 'Notion' },
  { slug: 'airtable', name: 'Airtable' },
  { slug: 'calendly', name: 'Calendly' },
  { slug: 'googlecalendar', name: 'Google Calendar' },
  { slug: 'googledrive', name: 'Google Drive' },
  { slug: 'dropbox', name: 'Dropbox' },
  { slug: 'mailchimp', name: 'Mailchimp' },
  { slug: 'asana', name: 'Asana' },
  { slug: 'trello', name: 'Trello' },
  { slug: 'zapier', name: 'Zapier' },
];
---

<section class="tools" aria-labelledby="tools-heading">
  <div class="tools-head" data-reveal>
    <h2 id="tools-heading">Connect to what you already use.</h2>
    <p>
      Your accounting, inbox, CRM, and calendar all stay. They just finally talk to each other.
    </p>
  </div>

  <div class="marquee" data-reveal>
    <div class="marquee-track">
      <ul class="marquee-list">
        {
          logos.map((logo) => (
            <li>
              <img src={`/logos/${logo.slug}.svg`} alt={logo.name} width="28" height="28" loading="lazy" />
            </li>
          ))
        }
      </ul>
      <ul class="marquee-list" aria-hidden="true">
        {
          logos.map((logo) => (
            <li>
              <img src={`/logos/${logo.slug}.svg`} alt="" width="28" height="28" loading="lazy" />
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .tools {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: calc(var(--section-pad-y) * 1.4) var(--section-pad-x);
  }

  .tools-head {
    max-width: 42rem;
    margin-bottom: 2.25rem;
  }

  .tools-head h2 {
    font-size: clamp(1.9rem, 3.6vw, 2.6rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin-bottom: 0.85rem;
    text-wrap: balance;
  }

  .tools-head p {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--site-text-dim);
    max-width: 36rem;
  }

  .marquee {
    overflow: hidden;
  }

  .marquee-list {
    list-style: none;
    padding: 0 0 0 4.5rem;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 4.5rem;
    flex-shrink: 0;
  }

  .marquee-list img {
    display: block;
    width: 1.75rem;
    height: 1.75rem;
    opacity: 0.75;
  }

  @media (prefers-reduced-motion: no-preference) {
    .marquee {
      mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
      -webkit-mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
    }

    .marquee-track {
      display: flex;
      width: max-content;
      animation: marquee-scroll 32s linear infinite;
    }

    .marquee:hover .marquee-track {
      animation-play-state: paused;
    }

    @keyframes marquee-scroll {
      to {
        transform: translateX(-50%);
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track > .marquee-list[aria-hidden='true'] {
      display: none;
    }

    .marquee-list {
      flex-wrap: wrap;
      justify-content: flex-start;
      gap: 2.5rem;
      padding-left: 0;
    }
  }
</style>
