---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<svg
  class:list={['logo-mark', className]}
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 28 18"
  width="28"
  height="18"
  fill="currentColor"
  aria-hidden="true"
>
  <rect x="1" y="1" width="26" height="6" />
  <rect x="1" y="11" width="26" height="6" />
</svg>

<style>
  .logo-mark {
    display: block;
    flex-shrink: 0;
    color: var(--site-accent);
  }
</style>
