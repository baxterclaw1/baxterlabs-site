---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<svg
  class:list={['logo-mark', className]}
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 18 22"
  width="18"
  height="22"
  fill="currentColor"
  aria-hidden="true"
>
  <rect x="2" y="1" width="14" height="8" />
  <rect x="2" y="13" width="14" height="8" />
</svg>

<style>
  .logo-mark {
    display: block;
    flex-shrink: 0;
    color: var(--site-accent);
  }
</style>
