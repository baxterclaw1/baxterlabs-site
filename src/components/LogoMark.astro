---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<svg
  class:list={['logo-mark', className]}
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 20 20"
  width="30"
  height="30"
  fill="currentColor"
  aria-hidden="true"
>
  <rect x="1" y="1" width="18" height="8" />
  <rect x="1" y="11" width="18" height="8" />
  <rect class="logo-eye" x="5.4" y="3.4" width="2.4" height="2.4" />
  <rect class="logo-eye" x="12.2" y="3.4" width="2.4" height="2.4" />
</svg>

<style>
  .logo-mark {
    display: block;
    flex-shrink: 0;
    color: var(--site-accent);
  }

  .logo-eye {
    fill: var(--site-bg);
  }
</style>
