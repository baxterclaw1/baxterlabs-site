---
import LogoMark from './LogoMark.astro';
---

<header class="nav">
  <a class="nav-logo" href="/">
    <LogoMark />
    <span>BaxterLabs</span>
  </a>
  <a class="btn" href="#contact">Book a Call</a>
</header>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem var(--section-pad-x);
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .nav-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    text-decoration: none;
  }
</style>
