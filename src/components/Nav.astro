---
import LogoMark from './LogoMark.astro';
---

<header class="nav">
  <a class="nav-logo" href="/">
    <LogoMark />
    <span>BaxterLabs</span>
  </a>
  <a class="nav-contact" href="#contact">Contact</a>
</header>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem var(--section-pad-x);
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .nav-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    text-decoration: none;
  }

  .nav-contact {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--site-text-dim);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .nav-contact:hover {
    color: var(--site-text);
  }
</style>
