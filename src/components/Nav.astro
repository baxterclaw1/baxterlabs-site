---
import LogoMark from './LogoMark.astro';
---

<header class="nav">
  <div class="nav-inner">
    <a class="nav-logo" href="/">
      <LogoMark />
      <span>BaxterLabs</span>
    </a>
  </div>
</header>

<style>
  .nav {
    width: 100%;
    background: var(--site-bg);
    position: relative;
    z-index: 2;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 1.25rem var(--section-pad-x);
    max-width: var(--content-width);
    width: 100%;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .nav-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-width: 0;
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    text-decoration: none;
  }

  .nav-logo span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .nav-logo :global(svg) {
    width: 30px;
    height: 30px;
    flex-shrink: 0;
  }

  @media (max-width: 520px) {
    .nav-inner {
      padding: 1rem var(--section-pad-x);
    }

    .nav-logo {
      font-size: 1.05rem;
      gap: 0.3rem;
    }

    .nav-logo :global(svg) {
      width: 22px;
      height: 22px;
    }
  }

  @media (max-width: 360px) {
    .nav-logo {
      font-size: 0.95rem;
    }
  }
</style>
