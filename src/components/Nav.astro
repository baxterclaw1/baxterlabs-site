---
import LogoMark from './LogoMark.astro';
---

<header class="nav">
  <a class="nav-logo" href="/">
    <LogoMark />
    <span>BaxterLabs</span>
  </a>
  <a class="btn nav-cta" href="#contact" data-scroll-to="contact">Book a Call</a>
</header>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1.25rem var(--section-pad-x);
    max-width: var(--content-width);
    width: 100%;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .nav-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-width: 0;
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    text-decoration: none;
  }

  .nav-logo span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .nav-logo :global(svg) {
    width: 30px;
    height: 30px;
    flex-shrink: 0;
  }

  .nav-cta {
    flex-shrink: 0;
  }

  @media (max-width: 520px) {
    .nav {
      padding: 1rem var(--section-pad-x);
      gap: 0.5rem;
    }

    .nav-logo {
      font-size: 1.05rem;
      gap: 0.3rem;
    }

    .nav-logo :global(svg) {
      width: 22px;
      height: 22px;
    }

    .nav-cta {
      padding: 0.5rem 0.75rem;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 360px) {
    .nav-logo {
      font-size: 0.95rem;
    }

    .nav-cta {
      padding: 0.45rem 0.6rem;
      font-size: 0.7rem;
    }
  }
</style>
