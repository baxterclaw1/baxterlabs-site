---
import capabilities from '../data/capabilities.json';

const { shapes } = capabilities;
---

<section class="site-section site-section--intro" id="what-we-build" aria-labelledby="build-heading">
  <div class="site-section-head site-section-head--center">
    <p class="site-section-eyebrow">What we build</p>
    <h2 id="build-heading">Systems for how you actually operate</h2>
    <p class="site-section-lead">
      Common systems we build for operators. Yours will look different. We design around how you actually work.
    </p>
  </div>

  <div class="shape-list">
    {
      shapes.map((shape) => (
        <article class="shape-item">
          <h3>{shape.title}</h3>
          <p>{shape.description}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .site-section-head--center {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  .site-section-head--center .site-section-lead {
    margin-left: auto;
    margin-right: auto;
  }

  .shape-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 22rem));
    justify-content: center;
    gap: 1.75rem 3rem;
    margin-top: 2.25rem;
  }

  @media (max-width: 720px) {
    .shape-list {
      grid-template-columns: 1fr;
      max-width: 28rem;
      margin-left: auto;
      margin-right: auto;
    }
  }

  .shape-item {
    text-align: center;
  }

  .shape-item h3 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
  }

  .shape-item p {
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--site-text-dim);
  }
</style>
