---
---

<section class="runs" aria-labelledby="runs-heading">
  <img
    class="runs-mascot"
    src="/images/little-agent.jpg"
    width="1024"
    height="1024"
    loading="lazy"
    alt="The BaxterLabs helper mascot, two stacked coral blocks with eyes"
    data-reveal
  />
  <h2 id="runs-heading" data-reveal style="--reveal-delay: 0.08s">Then it runs. Quietly, every day.</h2>
  <p data-reveal style="--reveal-delay: 0.16s">
    On your infrastructure or ours, watched and maintained by us, adjusted as your business grows.
  </p>
</section>

<style>
  .runs {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: calc(var(--section-pad-y) * 1.8) var(--section-pad-x);
    text-align: center;
  }

  .runs-mascot {
    display: block;
    width: clamp(6rem, 10vw, 8.5rem);
    height: auto;
    margin: 0 auto 1.5rem;
  }

  .runs h2 {
    font-size: clamp(1.9rem, 3.6vw, 2.6rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin-bottom: 1rem;
    text-wrap: balance;
  }

  .runs p {
    font-size: clamp(1rem, 1.6vw, 1.125rem);
    line-height: 1.7;
    color: var(--site-text-dim);
    max-width: 32rem;
    margin: 0 auto;
    text-wrap: pretty;
  }
</style>
