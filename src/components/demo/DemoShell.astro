---
import storyData from '../../data/demo-story.json';
import StoryDemo from './StoryDemo.astro';
---

<section class="demo-shell" id="demo-shell">
  <div class="demo-frame-wrap">
    <div class="demo-frame-chrome">
      <div class="demo-frame-dots">
        <span></span><span></span><span></span>
      </div>
      <span class="demo-frame-url">demo.baxterlabs.io / walkthrough</span>
    </div>
    <div class="demo-frame-body">
      <StoryDemo />
    </div>
  </div>

  <p class="demo-caption">Guided walkthrough · fictional scenario · representative of what BaxterLabs builds</p>
</section>

<script define:vars={{ storyData }}>
  function initStoryDemo() {
    const shell = document.getElementById('demo-shell');
    const panel = shell?.querySelector('[data-demo-panel]');
    if (!panel) return;

    const steps = storyData.steps;
    const total = steps.length;
    let current = 0;
    let onClose = false;
    let intakeDone = false;

    const indicator = document.getElementById('story-indicator');
    const body = document.getElementById('story-body');
    const backBtn = document.getElementById('story-back');
    const nextBtn = document.getElementById('story-next');
    const toast = document.getElementById('demo-toast');
    const dots = panel.querySelectorAll('[data-story-dot]');

    const trigger = document.getElementById('story-trigger');
    const autofill = document.getElementById('story-autofill');
    const submit = document.getElementById('story-submit');

    function showToast(msg) {
      if (!toast) return;
      toast.textContent = msg;
      toast.classList.add('is-visible');
      setTimeout(() => toast.classList.remove('is-visible'), 2800);
    }

    function updateDots(index, isClose) {
      dots.forEach((dot, i) => {
        dot.classList.toggle('is-active', !isClose && i === index);
        dot.classList.toggle('is-done', isClose || i < index);
      });
    }

    function goToStep(index) {
      const isClose = index === 'close';
      onClose = isClose;
      current = isClose ? total - 1 : index;
      const step = isClose ? null : steps[index];

      panel.querySelectorAll('.story-scene').forEach((scene) => {
        const name = scene.getAttribute('data-scene');
        scene.classList.toggle('is-active', isClose ? name === 'close' : name === step?.view);
      });

      if (isClose) {
        updateDots(-1, true);
        indicator.textContent = storyData.close.label;
        body.textContent = storyData.close.narration;
        backBtn.disabled = false;
        nextBtn.textContent = 'Restart tour';
        nextBtn.disabled = false;
        return;
      }

      updateDots(index, false);
      indicator.textContent = `Step ${step.stepOf} of ${total} · ${step.label}`;
      body.textContent = step.narration;

      backBtn.disabled = index === 0;
      nextBtn.textContent = index === total - 1 ? 'Finish' : 'Next';

      if (step.view === 'intake' && intakeDone) {
        nextBtn.disabled = false;
      } else if (step.view === 'intake' && step.tryAction) {
        nextBtn.disabled = true;
      } else {
        nextBtn.disabled = false;
      }
    }

    function checkIntake() {
      const val = (trigger?.value || '').toLowerCase().replace(/\s/g, '');
      const match = val.includes('parkside');
      autofill?.classList.toggle('is-visible', match);
      if (submit) submit.disabled = !match;
    }

    trigger?.addEventListener('input', checkIntake);

    submit?.addEventListener('click', () => {
      intakeDone = true;
      showToast(storyData.steps[1].tryAction.submitToast);
      if (nextBtn) nextBtn.disabled = false;
    });

    backBtn?.addEventListener('click', () => {
      if (onClose) {
        goToStep(total - 1);
        return;
      }
      if (current > 0) goToStep(current - 1);
    });

    nextBtn?.addEventListener('click', () => {
      if (onClose) {
        intakeDone = false;
        if (trigger) trigger.value = '';
        autofill?.classList.remove('is-visible');
        if (submit) submit.disabled = true;
        goToStep(0);
        return;
      }
      if (current < total - 1) goToStep(current + 1);
      else goToStep('close');
    });

    goToStep(0);
  }

  initStoryDemo();
</script>

<style is:global>
  @import '../../styles/demo-tokens.css';
  @import '../../styles/demo-story.css';
</style>

<style>
  .demo-shell {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem 2rem;
  }

  .demo-frame-wrap {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.08),
      0 24px 48px rgba(0, 0, 0, 0.45);
  }

  .demo-frame-body {
    overflow: hidden;
  }

  .demo-frame-chrome {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    background: #1a1b20;
    border-bottom: 1px solid #25262c;
  }

  .demo-frame-dots {
    display: flex;
    gap: 6px;
  }

  .demo-frame-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #d1d1d6;
  }

  .demo-frame-dots span:first-child { background: #ff5f57; }
  .demo-frame-dots span:nth-child(2) { background: #febc2e; }
  .demo-frame-dots span:nth-child(3) { background: #28c840; }

  .demo-frame-url {
    font-size: 12px;
    color: #6b6b70;
    font-family: ui-monospace, monospace;
  }

  .demo-caption {
    font-size: 0.8125rem;
    color: var(--site-text-dim);
    text-align: center;
    margin-top: 1rem;
  }
</style>
